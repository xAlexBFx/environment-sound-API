# Backend Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
HOST=0.0.0.0
DEBUG=false

# CORS Settings
# Comma-separated list of allowed origins, or * for all
ALLOWED_ORIGINS=*

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Model Cache
# Set to a directory path to cache YAMNet model, or leave empty for default
MODEL_CACHE_DIR=

# Logging
LOG_LEVEL=INFO

# Health Check
HEALTH_CHECK_ENABLED=true
